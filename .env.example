# Copy this file to `.env` (which is git-ignored) before running
# docker compose. Without these set, the stack starts with insecure
# defaults intended only for local dev.

# ── Required for any non-throwaway deployment ───────────────────────────────

# JWT signing key. If empty, qmetry generates a random one at boot but it
# rotates on every restart and invalidates every active session.
# Generate with:  openssl rand -hex 32
QMETRY_JWT_SECRET=

# Bootstrap admin password — applied on first boot only (when the users
# table is empty). Change this before exposing publicly. The default
# "admin" is intentional bait so the README can demo a clear warning.
QMETRY_INITIAL_PASSWORD=

# Optional override of the initial admin email.
# QMETRY_INITIAL_ADMIN=admin@yourdomain.com

# ClickHouse password — wired into both the clickhouse container and the
# qmetry container so they agree.
CLICKHOUSE_PASSWORD=

# ── Demo mode (ONLY for public preview deployments) ─────────────────────────

# When true, /api/auth/config returns the bootstrap admin credentials so
# the login page pre-fills them and shows a "Demo mode" banner.
# DO NOT enable in production: anyone hitting /api/auth/config gets the
# admin password.
# QMETRY_DEMO_MODE=true

# ── Cloudflare Tunnel (optional, activated by --profile tunnel) ─────────────

# Leave empty to use a quick (ephemeral) trycloudflare.com URL on every
# startup. For a persistent URL on your own domain:
#   1. Open https://one.dash.cloudflare.com/ → Networks → Tunnels → Create
#   2. Pick "cloudflared", copy the token shown after creation
#   3. Paste it here, then in the dashboard add a public hostname pointing
#      to http://qmetry:8088 (the tunnel resolves docker network names)
CLOUDFLARE_TUNNEL_TOKEN=

# ── OIDC (optional) ─────────────────────────────────────────────────────────

# QMETRY_OIDC_ENABLED=true
# QMETRY_OIDC_ISSUER_URL=https://accounts.google.com
# QMETRY_OIDC_CLIENT_ID=
# QMETRY_OIDC_CLIENT_SECRET=
# QMETRY_OIDC_REDIRECT_URL=https://qmetry.example.com/api/auth/oidc/callback
