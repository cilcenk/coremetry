{
  "name": "coremetry-ui",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:analyze": "tsc --noEmit && ANALYZE=1 vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/context-zone": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation": "^0.219.0",
    "@opentelemetry/instrumentation-document-load": "^0.64.0",
    "@opentelemetry/instrumentation-fetch": "^0.219.0",
    "@opentelemetry/instrumentation-user-interaction": "^0.63.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-virtual": "^3.14.3",
    "@types/dagre": "^0.7.54",
    "dagre": "^0.8.5",
    "lucide-react": "^1.21.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.28.0",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@types/node": "20.16.5",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "5.5.4",
    "typescript-eslint": "^8.61.1",
    "vite": "5.4.10",
    "vitest": "^2.1.8"
  }
}
